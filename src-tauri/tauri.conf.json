{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SWEX-NG",
  "version": "0.1.0",
  "identifier": "com.diegomn.swexng",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SWEX-NG",
        "width": 920,
        "height": 680,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENCOTQyNEIxQjJEOThCNEIKUldSTGk5bXlzU1NVeXhJQkRLVjFSSldlSTlNRE9WY25tTU5iempaeEhLRFlVclZJcXZwbGNyRisK",
      "endpoints": [
        "https://github.com/diegomnDev/swex-ng/releases/latest/download/latest.json"
      ]
    }
  }
}
